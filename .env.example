# ——— OpenRouter (по умолчанию, бесплатно) ———
# Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ——— Groq (бесплатный тариф) ———
# GROQ_API_KEY=gsk_...

# ——— DeepSeek (нужен баланс) ———
# DEEPSEEK_API_KEY=sk-...

# ——— OpenAI (подписка/кредиты) ———
# OPENAI_API_KEY=sk-...

# ——— Любой OpenAI-совместимый API (provider: openai_compatible) ———
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://api.example.com/v1

# Опциональные переопределения (для любого провайдера)
# LLM_PROVIDER=openrouter
# LLM_MODEL=openrouter/free
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=4096
