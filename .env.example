# ============================================================
# Для запуска с нуля достаточно одного ключа — OpenRouter (бесплатно).
# Остальное — по желанию при смене провайдера.
# ============================================================

# OpenRouter — по умолчанию в config/agent.yml (рекомендуется)
# Ключ: https://openrouter.ai/keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-...

# --- Другие провайдеры (в config/agent.yml указать provider и model) ---

# Groq (бесплатный тариф): https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# DeepSeek (нужен баланс): https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-...

# OpenAI (нужны кредиты): https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Любой OpenAI-совместимый API (provider: openai_compatible в config)
# LLM_API_KEY=...
# LLM_BASE_URL=https://api.example.com/v1

# --- Опционально: переопределить конфиг через .env ---
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-70b-versatile
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=4096
